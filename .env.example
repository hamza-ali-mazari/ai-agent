# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_secure_api_key_here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_MODEL=gpt-4o-india-atul-b2b
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# GitHub Integration (optional)
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
GITHUB_DEEP_ANALYSIS=false

# Bitbucket Integration (optional)
# ! SECURITY WARNING: Never commit real tokens to git
# Use BITBUCKET_TOKEN for Bearer token authentication (repository access token)
# Generate a token at: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_TOKEN=your_bitbucket_token_here

# Optional: For Bitbucket Server/Data Center
BITBUCKET_SERVER_TOKEN=your_server_token_here
BITBUCKET_SERVER_URL=https://your-bitbucket-server.com

# Webhook configuration
BITBUCKET_WEBHOOK_SECRET=your_webhook_secret_here

# Database Configuration (if using SQL database)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here
DB_NAME=ai_review_engine

# Kafka Configuration
# Broker URLs - comma-separated for cluster setup
KAFKA_BROKER_URL=localhost:9092
# KAFKA_BROKER_URL=broker1.example.com:9092,broker2.example.com:9092,broker3.example.com:9092

# Topic and partition configuration
KAFKA_TOPIC_PREFIX=code-review
KAFKA_PARTITIONS=1
KAFKA_REPLICATION_FACTOR=1

# Kafka timeouts and connections
KAFKA_TIMEOUT_MS=30000
KAFKA_SOCKET_TIMEOUT_MS=60000

# Kafka Producer Settings
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_BATCH_SIZE=16384
KAFKA_PRODUCER_LINGER_MS=100
KAFKA_PRODUCER_COMPRESSION=snappy
KAFKA_PRODUCER_IDEMPOTENCE=true

# Kafka Consumer Settings
KAFKA_CONSUMER_AUTO_COMMIT=false
KAFKA_CONSUMER_AUTO_COMMIT_INTERVAL=5000
KAFKA_CONSUMER_SESSION_TIMEOUT=6000
KAFKA_CONSUMER_GROUP_ID=ai-code-review-engine

# Kafka Security Configuration
# Options: PLAINTEXT, SSL, SASL_PLAINTEXT, SASL_SSL
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SECURITY_PROTOCOL=SASL_SSL

# SASL Authentication (if using SASL_SSL or SASL_PLAINTEXT)
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_SASL_USERNAME=your_kafka_username
# KAFKA_SASL_PASSWORD=your_kafka_password

# SSL/TLS Certificates (if using SSL or SASL_SSL)
# KAFKA_SSL_CAFILE=/path/to/ca-cert
# KAFKA_SSL_CERTFILE=/path/to/client-cert
# KAFKA_SSL_KEYFILE=/path/to/client-key

# Service Endpoints Configuration
# AI Review API URL (for Bitbucket integration callbacks)
AI_REVIEW_API_URL=http://localhost:8000

# Chatbot API URL (for chat UI access)
CHATBOT_API_URL=http://localhost:10000

# CORS Configuration
# Comma-separated list of allowed origins (for development, defaults to localhost)
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# For production, configure specific domains:
# ALLOWED_CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# Deployment environment (development or production)
ENVIRONMENT=development

# Security Settings
LOG_LEVEL=INFO
DEBUG=false
TESTING=false
