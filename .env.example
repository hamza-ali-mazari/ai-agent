# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_secure_api_key_here
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_MODEL=gpt-4o-india-atul-b2b
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# GitHub Integration (optional)
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here
GITHUB_DEEP_ANALYSIS=false

# Bitbucket Integration (optional)
# ! SECURITY WARNING: Never commit real tokens to git
# Use BITBUCKET_TOKEN for Bearer token authentication (repository access token)
# Generate a token at: https://bitbucket.org/account/settings/app-passwords/
BITBUCKET_TOKEN=your_bitbucket_token_here

# Optional: For Bitbucket Server/Data Center
BITBUCKET_SERVER_TOKEN=your_server_token_here
BITBUCKET_SERVER_URL=https://your-bitbucket-server.com

# Webhook configuration
BITBUCKET_WEBHOOK_SECRET=your_webhook_secret_here

# Database Configuration (if using SQL database)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here
DB_NAME=ai_review_engine

# Security Settings
LOG_LEVEL=INFO
DEBUG=false
